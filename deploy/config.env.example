# ============================================================
#  KUBUS — Konfigurasi Deployment VPS
#  Salin file ini menjadi config.env lalu ubah nilainya:
#    cp deploy/config.env.example deploy/config.env
#    nano deploy/config.env
# ============================================================

# Domain ATAU IP publik VPS Anda (tanpa http://). Contoh: kubus.id  atau  203.0.113.10
DOMAIN="ganti-dengan-domain-atau-ip"

# Set "true" HANYA setelah domain diarahkan ke VPS dan SSL (certbot) sudah aktif.
USE_HTTPS="false"

# (Opsional) API key Anthropic untuk mengaktifkan fitur AI (Claude).
# Kosongkan jika belum punya — situs tetap jalan, fitur AI nonaktif sementara.
# Dapatkan di: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# MongoDB lokal di VPS (default). Ganti jika pakai Atlas.
MONGO_URL="mongodb://localhost:27017"
DB_NAME="kubus_prod"

# Secret untuk JWT — WAJIB diganti dengan string acak panjang.
JWT_SECRET="ganti-dengan-secret-acak-yang-panjang-dan-unik"

# Kredensial untuk halaman /docs (Swagger) backend.
DOCS_USERNAME="admin"
DOCS_PASSWORD="ganti-password-docs"

# (Opsional) Email untuk notifikasi pembaruan sertifikat SSL dari Let's Encrypt.
# Jika kosong, script ssl akan menggunakan admin@<DOMAIN> sebagai default.
LETS_ENCRYPT_EMAIL=""
